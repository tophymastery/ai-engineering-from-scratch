{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.shop.io/events/profile.erased/v1.schema.json",
  "title": "profile.erased v1",
  "description": "Emitted by identity-profile when a user's PII is crypto-shredded (V-T2 / D3, right-to-erasure). TOKEN-ONLY payload — the erasure itself is announced with usr_/adr_ tokens, never PII. Downstreams drop cached PII on this event; token-keyed history (orders) is unaffected. Key aggregate:user_token.",
  "x-topic": "profile.erased",
  "x-schema-version": 1,
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "trace_id", "aggregate", "schema_version", "payload"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "const": "profile.erased" },
    "occurred_at": { "type": "string" },
    "trace_id": { "type": "string" },
    "aggregate": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "const": "profile" },
        "id": { "type": "string", "description": "usr_ token — never PII (D3)." },
        "region": { "type": "string" }
      }
    },
    "schema_version": { "type": "integer" },
    "payload": {
      "type": "object",
      "required": ["user_token", "jurisdiction", "action"],
      "properties": {
        "user_token": { "type": "string", "description": "usr_ token — never PII (D3)." },
        "jurisdiction": { "type": "string" },
        "action": { "type": "string", "description": "erased" },
        "addr_tokens": {
          "type": "array",
          "items": { "type": "string", "description": "adr_ token — never PII (D3)." }
        }
      }
    }
  }
}
