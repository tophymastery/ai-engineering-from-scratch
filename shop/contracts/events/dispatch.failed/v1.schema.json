{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.shop.io/events/dispatch.failed/v1.schema.json",
  "title": "dispatch.failed v1",
  "description": "Emitted by dispatch (V-T12) → order when no driver could be matched within the batch (D13). Drives the order saga's dispatch-exhausted compensation (refund + cancel). Key region:order_id (02 §4.3). D30: additive-only within this topic.",
  "x-topic": "dispatch.failed",
  "x-schema-version": 1,
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "trace_id", "aggregate", "schema_version", "payload"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "const": "dispatch.failed" },
    "occurred_at": { "type": "string" },
    "trace_id": { "type": "string" },
    "aggregate": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "const": "order" },
        "id": { "type": "string" },
        "region": { "type": "string" }
      }
    },
    "schema_version": { "type": "integer" },
    "payload": {
      "type": "object",
      "required": ["order_id", "failed_at"],
      "properties": {
        "order_id": { "type": "string" },
        "reason": { "type": "string" },
        "failed_at": { "type": "string" }
      }
    }
  }
}
