{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.shop.io/events/payment.failed/v1.schema.json",
  "title": "payment.failed v1",
  "description": "Emitted by payment → order (compensation), notification when an authorization is declined or fails. Key region:order_id (02 §4.3). D30: additive-only within this topic.",
  "x-topic": "payment.failed",
  "x-schema-version": 1,
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "trace_id", "aggregate", "schema_version", "payload"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "const": "payment.failed" },
    "occurred_at": { "type": "string" },
    "trace_id": { "type": "string" },
    "aggregate": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "const": "order" },
        "id": { "type": "string" },
        "region": { "type": "string" }
      }
    },
    "schema_version": { "type": "integer" },
    "payload": {
      "type": "object",
      "required": ["payment_id", "order_id", "reason"],
      "properties": {
        "payment_id": { "type": "string" },
        "order_id": { "type": "string" },
        "reason": { "type": "string" },
        "failed_at": { "type": "string" }
      }
    }
  }
}
