{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.shop.io/events/order.created/v1.schema.json",
  "title": "order.created v1",
  "description": "Emitted by order → payment, dispatch, notification, settlement. Key region:order_id (02 §4.3). D30: additive-only within this topic.",
  "x-topic": "order.created",
  "x-schema-version": 1,
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "trace_id", "aggregate", "schema_version", "payload"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "const": "order.created" },
    "occurred_at": { "type": "string" },
    "trace_id": { "type": "string" },
    "aggregate": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "const": "order" },
        "id": { "type": "string" },
        "region": { "type": "string" }
      }
    },
    "schema_version": { "type": "integer" },
    "payload": {
      "type": "object",
      "required": ["order_id", "customer_id", "status", "total"],
      "properties": {
        "order_id": { "type": "string" },
        "customer_id": { "type": "string", "description": "usr_ token — never PII (D3)." },
        "status": { "type": "string" },
        "total": {
          "type": "object",
          "required": ["amount", "currency"],
          "properties": {
            "amount": { "type": "integer" },
            "currency": { "type": "string" }
          }
        },
        "item_count": { "type": "integer" }
      }
    }
  }
}
