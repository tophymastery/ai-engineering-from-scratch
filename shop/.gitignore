# Runtime state from `make up` (process-mode binaries, pidfiles, logs).
/.run/
# Transient Kustomize render output (make render cleans these, belt-and-braces).
/.render-*.yaml
# Compiled binaries from `go build ./...` run inside a module dir.
/gateway/gateway
/services/_placeholder/placeholder
# S-T7 fake-provider binaries (services build to .run/ in process mode).
/services/fakes/payment-sim/payment-sim
/services/fakes/map-sim/map-sim
/services/fakes/notify-sink/notify-sink
